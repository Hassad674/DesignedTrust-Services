# Mobile (Flutter) build-time configuration.
#
# The Flutter app does NOT read a .env file at runtime. Every value is
# baked in at build time via `--dart-define=KEY=VALUE` (see the
# `String.fromEnvironment(...)` calls under mobile/lib/core and
# lib/features). All keys are optional — each has an in-code default
# so a bare `flutter run` works against the local dev backend.
#
# Two ways to pass them:
#
# 1. Inline flags:
#      flutter run \
#        --dart-define=API_URL=http://192.168.1.50:8083 \
#        --dart-define=WEB_ORIGIN_URL=http://192.168.1.50:3001
#
# 2. From this file (Flutter 3.7+), after copying it to a real file
#    (e.g. `mobile/dart-defines.env`) and filling in values:
#      flutter run --dart-define-from-file=dart-defines.env
#
# NOTE: use a LAN IP (not localhost) so a physical device or emulator
# can reach the backend running on your machine.

# --- Core API ---------------------------------------------------------
# Backend API base URL. Default: http://192.168.1.156:8083
API_URL=http://192.168.1.156:8083

# --- WebView hand-off (subscribe / Stripe Embedded billing) -----------
# Base URL of the web app the in-app WebView opens. Default mirrors the
# local web dev server.
WEB_ORIGIN_URL=http://192.168.1.156:3001
# Same as above for the payment-info / KYC flow.
WEB_URL=http://192.168.1.156:3001
# next-intl locale segment prefixed onto handed-off web URLs (/fr/...).
WEB_LOCALE_SEGMENT=fr

# --- Calls ------------------------------------------------------------
# LiveKit wss:// endpoint for video/audio calls. Empty disables
# room-connect on mobile.
LIVEKIT_URL=

# --- Analytics --------------------------------------------------------
# PostHog public project token (same value as the web/backend key).
# Empty = analytics no-op. Use the EU host for RGPD scope.
POSTHOG_PROJECT_KEY=
POSTHOG_HOST=https://eu.posthog.com

# --- Certificate pinning (release builds) -----------------------------
# SHA-256 pins of the backend TLS certificate, hex-encoded. Empty in
# dev (pinning disabled). The release pipeline MUST pass both: ship the
# current cert as PRIMARY and the next-rotation cert as BACKUP for
# zero-downtime certificate rotation.
BACKEND_CERT_SHA256_PRIMARY=
BACKEND_CERT_SHA256_BACKUP=
