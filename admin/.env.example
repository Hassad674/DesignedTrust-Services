# Admin dashboard (Vite + React) environment.
#
# Vite only exposes variables prefixed with VITE_ to client code. Copy
# this file to `.env` (or `.env.local`) and adjust as needed:
#   cp admin/.env.example admin/.env

# Backend API base URL. Read by the API client and the admin WebSocket
# hook. Defaults to the local backend (port 8083) when unset.
VITE_API_URL=http://localhost:8083
