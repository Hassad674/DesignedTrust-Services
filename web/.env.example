# Backend API base URL — leave empty in production for proxy mode.
NEXT_PUBLIC_API_URL=http://localhost:8083

# Frontend canonical URL (used by metadata / SEO helpers).
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Public Typesense host. Read by the in-browser search client (via
# useSearchKey + the /api/v1/search/key response) when a component
# bypasses the backend proxy. Kept here as a fallback for SSR
# helpers that need the host before the first API call.
NEXT_PUBLIC_TYPESENSE_HOST=http://localhost:8108

# Stripe publishable key (pk_test_... in dev / pk_live_... in prod).
# Read by the client to mount Stripe Embedded Checkout via
# @stripe/react-stripe-js. Safe to ship to the browser — it's the
# public counterpart to STRIPE_SECRET_KEY which stays server-side.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# PostHog analytics (browser SDK). Public project token — same value
# the backend uses as POSTHOG_PROJECT_KEY. Empty key disables
# analytics in the browser. Use the EU host for RGPD scope.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# Google Analytics 4 (GA4) Measurement ID. Loaded by the
# @next/third-parties/google helper. Empty value = GA4 stays a no-op
# (no script injected). The cookie banner gates loading even when an
# ID is present — RGPD opt-in only.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# WebSocket endpoint for real-time messaging. Empty = the messaging
# socket is not opened (REST polling still works). Point at the backend
# host with a ws:// or wss:// scheme. Also whitelisted in the CSP
# connect-src directive when set.
NEXT_PUBLIC_WS_URL=

# LiveKit wss:// endpoint for in-browser video/audio calls. Empty =
# the call UI mounts but room-connect is skipped. Must match the
# backend LIVEKIT_URL project. Whitelisted in the CSP connect-src.
NEXT_PUBLIC_LIVEKIT_URL=

# Public base URL of the object store serving user uploads (avatars,
# documents). Whitelisted in the CSP img-src/media-src so uploaded
# media renders. In dev this is the MinIO public URL; in prod the R2
# public bucket URL. Empty = same-origin only.
NEXT_PUBLIC_STORAGE_URL=http://localhost:9000/marketplace

# --------------------------------------------------------------------
# Sentry error monitoring (browser + server). The SDK is fully
# env-gated: with NO DSN set it is completely inert (no init, no
# transport, zero overhead) so the app builds + runs identically.
# Set the DSN on Vercel to activate — no code deploy needed.
#   - NEXT_PUBLIC_SENTRY_DSN: project DSN. Read by the browser AND used
#     as the server/edge fallback. This is the only var required to
#     turn Sentry on. Ingest hosts are already whitelisted in the CSP.
#   - SENTRY_DSN: optional server/edge override (wins over the public
#     one). Leave unset to use NEXT_PUBLIC_SENTRY_DSN everywhere.
#   - SENTRY_AUTH_TOKEN / SENTRY_ORG / SENTRY_PROJECT: build-time only,
#     OPT-IN source-map upload. Unset = no upload, no build failure.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --------------------------------------------------------------------
# Legal identity (LCEN "Éditeur" + RGPD controller block shown on the
# public mentions-légales / CGU / CGV / privacy pages). All optional —
# each falls back to a baked-in production value in
# src/config/legal-issuer.ts, so the pages are never blank. Override on
# the host to correct the identity without a code deploy. These values
# are LEGALLY PUBLIC (a SIRET / VAT number / registered address must be
# disclosed on the site) — use your own entity's values. Placeholders
# below; leave unset to use the in-code defaults.
# --------------------------------------------------------------------
NEXT_PUBLIC_LEGAL_NAME=
NEXT_PUBLIC_LEGAL_TRADING_NAME=
NEXT_PUBLIC_LEGAL_FORM=
NEXT_PUBLIC_LEGAL_SIRET=
NEXT_PUBLIC_LEGAL_SIREN=
NEXT_PUBLIC_LEGAL_VAT=
NEXT_PUBLIC_LEGAL_APE=
NEXT_PUBLIC_LEGAL_APE_LABEL=
NEXT_PUBLIC_LEGAL_ADDRESS_LINE1=
NEXT_PUBLIC_LEGAL_POSTAL_CODE=
NEXT_PUBLIC_LEGAL_CITY=
NEXT_PUBLIC_LEGAL_COUNTRY=
NEXT_PUBLIC_LEGAL_RCS_MENTION=
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=
NEXT_PUBLIC_LEGAL_DPO_EMAIL=
NEXT_PUBLIC_LEGAL_DOMAIN=
