# Server
PORT=8083
ENV=development

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5435/marketplace_go?sslmode=disable
# Privileged (BYPASSRLS) connection used by the system-actor pool
# (schedulers, webhooks, GDPR purge, admin overrides). Optional —
# when empty the app falls back to DATABASE_URL with a WARN log. In
# production this should be a separate role that bypasses RLS. See
# backend/docs/rls-rollout.md.
DATABASE_URL_ADMIN=

# Redis
REDIS_URL=redis://localhost:6380

# JWT — JWT_SECRET MUST be a fresh 32+ byte value in production
# (the boot refuses the dev fallback). Generate: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h
# Server-side session lifetime (httpOnly cookie). Default 14 days.
SESSION_TTL=336h

# CORS
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:5173

# Canonical frontend URL — used in transactional emails and redirect
# links (e.g. password reset, KYC deep-links). Default is the local
# web dev server.
FRONTEND_URL=http://localhost:3001

# Comma-separated CIDR allow-list of trusted reverse proxies. The rate
# limiter honors X-Forwarded-For ONLY when the request's source IP is
# inside one of these CIDRs. Leave empty in local dev (no proxy); set
# to your load balancer's source range in production.
TRUSTED_PROXIES=

# Storage (MinIO local / Cloudflare R2 production)
# Local: MinIO runs in Docker, S3-compatible API
# Prod: Cloudflare R2 — same S3 API, zero egress fees
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=marketplace
STORAGE_USE_SSL=false
STORAGE_PUBLIC_URL=http://localhost:9000/marketplace

# Production R2 example:
# STORAGE_ENDPOINT=<account-id>.r2.cloudflarestorage.com
# STORAGE_ACCESS_KEY=<r2-access-key-id>
# STORAGE_SECRET_KEY=<r2-secret-access-key>
# STORAGE_BUCKET=marketplace
# STORAGE_USE_SSL=true
# STORAGE_PUBLIC_URL=https://pub-<hash>.r2.dev

# Search engine (Typesense) — MANDATORY since phase 4. The legacy
# SQL search path was retired in April 2026 after the 30-day grace
# period. `/ready` fails fast (503) when the cluster cannot be
# pinged so load balancers can rotate a misconfigured instance out.
TYPESENSE_HOST=http://localhost:8108
TYPESENSE_API_KEY=xyz-dev-master-key-change-in-production

# OpenAI embeddings powering the semantic half of the hybrid query.
# Required on the indexer + query path. Without a key the system
# falls back to a deterministic mock (dev-only — NEVER prod) and
# logs a WARN so the downgrade is visible.
# The golden semantic tests are gated behind OPENAI_EMBEDDINGS_LIVE=true (off by default).
OPENAI_API_KEY=sk-proj-placeholder
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# Invoicing — issuer (the marketplace's own legal identity stamped on
# every outbound invoice). All required fields must be set or the
# invoicing feature stays off at boot (invoice.paid webhook becomes a
# no-op). Use placeholder values in dev; set the real SIRET and
# address in production via the secret manager.
INVOICE_ISSUER_NAME="Marketplace Example SAS"
INVOICE_ISSUER_LEGAL_FORM="SAS"
INVOICE_ISSUER_ADDRESS_LINE1="1 rue de la République"
INVOICE_ISSUER_ADDRESS_LINE2=
INVOICE_ISSUER_POSTAL_CODE="75001"
INVOICE_ISSUER_CITY="Paris"
INVOICE_ISSUER_COUNTRY="FR"
INVOICE_ISSUER_SIRET="00000000000000"
INVOICE_ISSUER_APE_CODE="6201Z"
INVOICE_ISSUER_VAT_NUMBER=
INVOICE_ISSUER_EMAIL="billing@example.com"
INVOICE_ISSUER_PHONE=
INVOICE_ISSUER_IBAN=
INVOICE_ISSUER_RCS_EXEMPT="false"

# Text moderation provider — selects the adapter behind
# port/service.TextModerationService. All providers share the same
# rule engine (domain/moderation) so thresholds do not change when
# swapping. Valid values:
#   openai     (default, free, FR-native, requires OPENAI_API_KEY above)
#   comprehend (legacy AWS adapter — EN only, needs a region where
#               DetectToxicContent is available: us-east-1, us-west-2,
#               eu-west-2, ap-southeast-2)
#   noop       (disables moderation entirely — dev/CI only)
TEXT_MODERATION_PROVIDER=openai

# GDPR right-to-erasure (P5) — the anonymization salt used when the
# daily purge cron writes sha256(email + salt) into audit_logs metadata.
# MUST be set in production; the open-source dev fallback below is
# rejected by config.Validate() in production. Generate a fresh
# 32+ byte value with `openssl rand -base64 32`.
GDPR_ANONYMIZATION_SALT=dev-salt-not-for-prod

# OpenTelemetry (P11) — vendor-neutral OTLP exporter. When
# OTEL_EXPORTER_OTLP_ENDPOINT is empty (the default in dev / CI) the
# backend installs a no-op tracer with zero overhead and zero
# goroutines started. Set the endpoint in production to ship spans
# to your observability backend (Jaeger / Honeycomb / Datadog /
# Grafana Tempo all speak OTLP).
#
# OTEL_EXPORTER_OTLP_ENDPOINT  : host:port for grpc, full URL for http
# OTEL_EXPORTER_OTLP_PROTOCOL  : grpc (default) or http/protobuf
# OTEL_EXPORTER_OTLP_INSECURE  : true to disable TLS (gRPC only)
# OTEL_EXPORTER_OTLP_HEADERS   : k=v,k=v (e.g. tenant id, API key)
# OTEL_SERVICE_NAME            : default marketplace-backend
# OTEL_SERVICE_VERSION         : default dev (override with build tag)
# OTEL_RESOURCE_ATTRIBUTES     : extra k=v,k=v resource attributes
# OTEL_TRACES_SAMPLER_ARG      : sampling ratio 0..1, default 1
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_EXPORTER_OTLP_INSECURE=false
OTEL_SERVICE_NAME=marketplace-backend
OTEL_SERVICE_VERSION=dev
OTEL_TRACES_SAMPLER_ARG=1.0

# Rate limiter overrides (PERF-FIX-W-IDLE-CPU). 0 / unset means use
# the documented production defaults: 100 / 30 / 10 req/min for the
# global IP / per-user mutation / per-user upload classes. Bump
# RATE_LIMIT_GLOBAL_PER_MINUTE locally when iterating across
# multiple browser tabs; production should keep the default.
RATE_LIMIT_GLOBAL_PER_MINUTE=0
RATE_LIMIT_MUTATION_PER_MINUTE=0
RATE_LIMIT_UPLOAD_PER_MINUTE=0

# AWS Rekognition image/video moderation thresholds.
#
# REKOGNITION_THRESHOLD doubles as the AWS `MinConfidence` parameter
# (labels below this are not even returned by Rekognition) AND as the
# "flag for human review" cutoff: once a label crosses this score, the
# media is marked `flagged` and surfaces in /admin/moderation.
#
# REKOGNITION_AUTO_REJECT_THRESHOLD is the score at which the system
# auto-rejects without human review. The source file is deleted from
# storage and the media row is marked `rejected`.
#
# INVARIANT: REKOGNITION_THRESHOLD < REKOGNITION_AUTO_REJECT_THRESHOLD.
# Inverting the two makes every label end up auto-rejected (the flagged
# bucket becomes unreachable) — see the config_threshold_test guardrail.
REKOGNITION_THRESHOLD=60
REKOGNITION_AUTO_REJECT_THRESHOLD=95

# PostHog analytics (server-side capture). The project key is the
# PUBLIC PostHog token — same value as web's NEXT_PUBLIC_POSTHOG_KEY
# and mobile's --dart-define=POSTHOG_PROJECT_KEY. PostHog deliberately
# shares the public token between server and client. Empty key
# disables analytics with a WARN log; never fatal at boot.
# Use the EU host (https://eu.posthog.com) for RGPD scope — the EU
# project keeps personal data in Ireland.
POSTHOG_PROJECT_KEY=
POSTHOG_HOST=https://eu.posthog.com

# --------------------------------------------------------------------
# Payments — Stripe Connect (escrow, payouts, KYC via Embedded
# Components). All three empty = payments feature stays off (no charge
# or payout endpoint is wired). Use pk_test_/sk_test_ keys in dev.
# STRIPE_WEBHOOK_SECRET is the signing secret printed by
# `stripe listen` or shown in the Stripe dashboard webhook settings.
# --------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# --------------------------------------------------------------------
# Video + audio calls — LiveKit. All three required to enable calls;
# empty = the call feature is disabled (room-connect is skipped).
# LIVEKIT_URL is the wss:// endpoint of your LiveKit Cloud project or
# self-hosted server.
# --------------------------------------------------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --------------------------------------------------------------------
# Transactional email — Resend. Empty RESEND_API_KEY disables outbound
# email (links/codes are logged instead in dev). EMAIL_FROM must be an
# RFC 5322 sender on a domain you verified in Resend. In dev/staging,
# set RESEND_DEV_REDIRECT_TO to funnel every outbound email to a single
# inbox (sandbox).
# --------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Marketplace Service <onboarding@resend.dev>
RESEND_DEV_REDIRECT_TO=

# --------------------------------------------------------------------
# Push notifications — Firebase Cloud Messaging. Path to the service
# account JSON. Empty = push delivery disabled (in-app notifications
# still work).
# --------------------------------------------------------------------
FCM_CREDENTIALS_PATH=

# --------------------------------------------------------------------
# Image + video moderation — AWS Rekognition. REKOGNITION_ENABLED=true
# turns on synchronous image moderation. Async video moderation needs
# the full pack: S3 transit bucket + SNS topic + SQS queue + IAM role
# (see config.VideoModerationConfigured). AWS_REGION is the default
# region; REKOGNITION_REGION overrides it for the moderation calls
# (DetectModerationLabels must be available there).
# --------------------------------------------------------------------
REKOGNITION_ENABLED=false
AWS_REGION=eu-west-1
REKOGNITION_REGION=
REKOGNITION_ROLE_ARN=
S3_MODERATION_BUCKET=
SNS_TOPIC_ARN=
SQS_QUEUE_URL=

# Cold-tier audit log archive bucket (gzipped JSONL bundles older than
# the cold-tier cutoff are uploaded here). Empty = archival disabled.
# May equal STORAGE_BUCKET — keys are namespaced under audit-cold/.
STORAGE_AUDIT_COLD_BUCKET=

# Anthropic API key — optional, used by AI-assisted backend paths when
# present. Empty disables them.
ANTHROPIC_API_KEY=

# RGPD art. 22 admin notification recipient (human-review appeals).
# Empty silences the email; the appeal row is still persisted.
GDPR_CONTACT_EMAIL=

# --------------------------------------------------------------------
# Rate-limit overrides (per minute). 0 / unset = use the safe-for-prod
# defaults baked into the middleware. Auth/2FA/password-reset classes
# are intentionally tight — loosen only with a threat-model rationale.
# --------------------------------------------------------------------
RATE_LIMIT_AUTH_LOGIN_PER_MINUTE=0
RATE_LIMIT_AUTH_2FA_VERIFY_PER_MINUTE=0
RATE_LIMIT_AUTH_2FA_ENABLE_PER_MINUTE=0
RATE_LIMIT_PASSWORD_RESET_PER_MINUTE=0

# Notification delivery worker pool size. 0 falls back to the default (5).
NOTIFICATION_WORKER_CONCURRENCY=5
